---
// Echtes 3D: prozedural erzeugter Backenzahn (Molar) als Drahtgitter mit drei
// Wurzeln und pulsierendem Schmerz-Leuchten an einer Wurzelspitze.
// Three.js wird selbst gehostet und von Astro/Vite gebündelt (kein CDN).
---

<div class="tooth" aria-hidden="true">
  <div id="tooth-3d" class="tooth__canvas"></div>
</div>

<style>
  .tooth {
    position: absolute;
    top: 50%;
    right: 4%;
    transform: translateY(-50%);
    width: clamp(260px, 36vw, 540px);
    aspect-ratio: 3 / 4;
    z-index: 0;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .tooth {
      right: 50%;
      transform: translate(50%, -50%);
      opacity: 0.55;
      width: clamp(280px, 80vw, 460px);
    }
  }

  .tooth__canvas { width: 100%; height: 100%; }
  .tooth__canvas :global(canvas) { display: block; width: 100% !important; height: 100% !important; }
</style>

<script>
  import * as THREE from "three";

  const mount = document.getElementById("tooth-3d");
  if (mount) {
    try {
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const lineMat = new THREE.LineBasicMaterial({
        color: 0xffffff,
        transparent: true,
        opacity: 0.55,
      });
      // Undurchsichtige, sehr dunkle Hülle: verdeckt die hinteren Gitterlinien,
      // damit man nicht durch den Zahn hindurchsieht. PolygonOffset hält die
      // vorderen Linien sichtbar (kein Z-Fighting).
      const skinMat = new THREE.MeshBasicMaterial({
        color: 0x0a0d0c,
        side: THREE.DoubleSide,
        polygonOffset: true,
        polygonOffsetFactor: 1,
        polygonOffsetUnits: 1,
      });

      // ── Szene aufbauen ──────────────────────────────────────────────
      const scene = new THREE.Scene();
      const pivot = new THREE.Group();
      const tooth = new THREE.Group();
      scene.add(pivot);
      pivot.add(tooth);
      pivot.rotation.x = 0.5; // nach vorn gekippt
      tooth.position.y = -0.1;

      const smooth = (e0: number, e1: number, x: number) => {
        const t = Math.min(1, Math.max(0, (x - e0) / (e1 - e0)));
        return t * t * (3 - 2 * t);
      };

      // Kaufläche als Tal: zentrale Mulde, erhöhter Höckerrand mit vier Höckern.
      const occl = (a: number, y: number, D: number) => {
        const m = smooth(1.1, 1.74, y);
        const dip = -0.18 * Math.exp(-((D / 0.42) ** 2));
        const rim = 0.07 * Math.exp(-(((D - 0.64) / 0.5) ** 2));
        const cusps = 0.15 * Math.cos(4 * a) * Math.exp(-(((D - 0.62) / 0.42) ** 2));
        return (dip + rim + cusps) * m;
      };

      // Baut aus einem Gitter P(i,j) einen eigenen Körper: massive Hülle + Linien.
      // So konvergieren die Linien jeder Wurzel an ihrer EIGENEN Spitze.
      const addPiece = (P: (i: number, j: number) => number[], rows: number, cols: number) => {
        const verts: number[][][] = [];
        for (let i = 0; i < rows; i++) {
          const r: number[][] = [];
          for (let j = 0; j < cols; j++) r.push(P(i, j));
          verts.push(r);
        }
        const pos: number[] = [], idx: number[] = [];
        for (let i = 0; i < rows; i++) for (let j = 0; j < cols; j++) pos.push(...verts[i][j]);
        for (let i = 0; i < rows - 1; i++)
          for (let j = 0; j < cols; j++) {
            const j2 = (j + 1) % cols;
            const a = i * cols + j, b = i * cols + j2;
            const c = (i + 1) * cols + j, d = (i + 1) * cols + j2;
            idx.push(a, c, b, b, c, d);
          }
        const sg = new THREE.BufferGeometry();
        sg.setAttribute("position", new THREE.Float32BufferAttribute(pos, 3));
        sg.setIndex(idx);
        tooth.add(new THREE.Mesh(sg, skinMat));

        const lp: number[] = [];
        for (let i = 0; i < rows; i++)
          for (let j = 0; j < cols; j++) {
            lp.push(...verts[i][j], ...verts[i][(j + 1) % cols]);
            if (i < rows - 1) lp.push(...verts[i][j], ...verts[i + 1][j]);
          }
        const lg = new THREE.BufferGeometry();
        lg.setAttribute("position", new THREE.Float32BufferAttribute(lp, 3));
        tooth.add(new THREE.LineSegments(lg, lineMat));
      };

      // ── Krone (eigener Körper, schließt unten zu einem Punkt) ───────
      const crownProfile: [number, number][] = [
        [0.00, 1.74], [0.38, 1.72], [0.66, 1.66], [0.88, 1.54], [1.02, 1.34],
        [1.08, 1.10], [1.04, 0.86], [0.92, 0.60], [0.80, 0.40], [0.68, 0.22],
        [0.58, 0.06], [0.46, -0.08], [0.28, -0.18], [0.0, -0.26],
      ];
      const CCOLS = 104;
      addPiece((i, j) => {
        const [r0, y0] = crownProfile[i];
        const a = (2 * Math.PI * j) / CCOLS;
        const shape = 1 + (0.14 * Math.cos(2 * a) - 0.06 * Math.cos(4 * a)) * smooth(0.32, 0.9, y0);
        const rr = r0 * shape;
        return [rr * Math.cos(a), y0 + occl(a, y0, rr), rr * Math.sin(a)];
      }, crownProfile.length, CCOLS);

      // ── Drei Wurzeln (je eigener Schlauch, verjüngt zur eigenen Spitze) ──
      const roots = [
        { az: 0,                     h: 2.15, baseR: 0.42, spread: 0.50, hook: 0.12, glow: true  }, // palatinal, vorn
        { az: (124 * Math.PI) / 180, h: 2.05, baseR: 0.44, spread: 0.60, hook: 0.16, glow: false }, // mesiobukkal
        { az: (236 * Math.PI) / 180, h: 2.2,  baseR: 0.40, spread: 0.55, hook: 0.14, glow: false }, // distobukkal
      ];
      const rootTopY = 0.44, d0 = 0.16, flareTop = 0.22;
      const RROWS = 46, RCOLS = 30;
      for (const rt of roots) {
        addPiece((i, j) => {
          const t = i / (RROWS - 1);
          const d = d0 + rt.spread * t ** 0.9 - rt.hook * t ** 4;
          const yy = rootTopY - rt.h * t;
          const rr = rt.baseR * (1 - t) ** 0.9 + flareTop * Math.exp(-((t / 0.18) ** 2));
          const cx = d * Math.sin(rt.az), cz = d * Math.cos(rt.az);
          const a = (2 * Math.PI * j) / RCOLS;
          return [cx + rr * Math.cos(a), yy, cz + rr * Math.sin(a)];
        }, RROWS, RCOLS);
      }

      // Schmerz-Anker an der palatinalen Wurzelspitze
      const pal = roots[0];
      const palD = d0 + pal.spread - pal.hook;
      const glowAnchor: THREE.Object3D = new THREE.Object3D();
      glowAnchor.position.set(palD * Math.sin(pal.az), rootTopY - pal.h, palD * Math.cos(pal.az));
      tooth.add(glowAnchor);

      // ── Schmerz-Leuchten (Sprite mit weichem Verlauf, additiv) ──────
      const makeGlowTexture = () => {
        const c = document.createElement("canvas");
        c.width = c.height = 128;
        const ctx = c.getContext("2d")!;
        const grd = ctx.createRadialGradient(64, 64, 0, 64, 64, 64);
        grd.addColorStop(0, "rgba(214,176,90,0.95)");
        grd.addColorStop(0.2, "rgba(168,135,45,0.55)");
        grd.addColorStop(0.55, "rgba(168,135,45,0.16)");
        grd.addColorStop(1, "rgba(168,135,45,0)");
        ctx.fillStyle = grd;
        ctx.fillRect(0, 0, 128, 128);
        return new THREE.CanvasTexture(c);
      };
      const glowMat = new THREE.SpriteMaterial({
        map: makeGlowTexture(),
        transparent: true,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
        opacity: 0.45,
      });
      const glow = new THREE.Sprite(glowMat);
      glow.scale.set(1.5, 1.5, 1.5);
      (glowAnchor ?? tooth).add(glow);

      // ── Renderer + Kamera ───────────────────────────────────────────
      const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setClearColor(0x000000, 0);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      mount.appendChild(renderer.domElement);

      const camera = new THREE.PerspectiveCamera(32, 1, 0.1, 100);
      camera.position.set(0, 0.1, 7.6);
      camera.lookAt(0, 0, 0);

      const resize = () => {
        const w = mount.clientWidth || 1;
        const h = mount.clientHeight || 1;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      };
      resize();
      new ResizeObserver(resize).observe(mount);

      // ── Animationsschleife (pausiert außerhalb des Sichtbereichs) ───
      const clock = new THREE.Clock();
      let running = false;
      let frame = 0;

      const renderOnce = () => renderer.render(scene, camera);

      const loop = () => {
        if (!running) return;
        frame = requestAnimationFrame(loop);
        const dt = clock.getDelta();
        const t = clock.elapsedTime;
        if (!reduced) tooth.rotation.y += dt * 0.2;
        const pulse = 0.5 + 0.5 * Math.sin(t * 2.2);
        glow.scale.setScalar(1.7 + pulse * 1.0);
        glowMat.opacity = reduced ? 0.85 : 0.5 + pulse * 0.5;
        renderer.render(scene, camera);
      };

      const start = () => {
        if (running) return;
        running = true;
        clock.start();
        if (reduced) { renderOnce(); running = false; }
        else frame = requestAnimationFrame(loop);
      };
      const stop = () => {
        running = false;
        cancelAnimationFrame(frame);
      };

      if (reduced) {
        renderOnce();
      } else {
        new IntersectionObserver(
          (entries) => entries.forEach((e) => (e.isIntersecting ? start() : stop())),
          { threshold: 0.05 }
        ).observe(mount);
      }
    } catch (err) {
      // WebGL nicht verfügbar: Hero bleibt ohne Zahn, kein Fehler für den Nutzer.
      console.warn("Zahn-3D konnte nicht initialisiert werden:", err);
    }
  }
</script>
