---
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import "@styles/global.css";
import interWoff2 from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2";
import playfairWoff2 from "@fontsource/playfair-display/files/playfair-display-latin-700-normal.woff2";

interface Props {
  /** Kurzer Seitenname (Navigation, Title-Muster). */
  title: string;
  /** Optional vollständiger SEO-Title; überschreibt das Muster. */
  seoTitle?: string;
  description?: string;
  /** Eigene Titel/Texte fürs Teilen (OG/Twitter), sonst SEO-Werte. */
  socialTitle?: string;
  socialDescription?: string;
  /** Pfad zum Share-Bild 1200×630, Standard = Marken-Default. */
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  noIndex?: boolean;
  /** Zusätzliches JSON-LD (z. B. Article) für diese Seite. */
  structuredData?: object | object[];
}

const {
  title,
  seoTitle,
  description = "Standpunkt zur Gesundheitspolitik von Dr. Roman Kubetschek, Zahnarzt in Neubrandenburg.",
  socialTitle,
  socialDescription,
  ogImage = "/og/default.jpg",
  ogImageAlt = "Standpunkt von Dr. Roman Kubetschek zum Zahnärztemangel in Mecklenburg-Vorpommern",
  ogType = "website",
  noIndex = false,
  structuredData,
} = Astro.props;

const siteOrigin = Astro.site?.origin ?? "https://loewen-zahn.de";
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const pageTitle =
  seoTitle ??
  (title === "Start"
    ? "Zahnärztemangel in MV – Standpunkt Dr. Kubetschek"
    : `${title} | Dr. Roman Kubetschek`);
const ogTitle = socialTitle ?? pageTitle;
const ogDesc = socialDescription ?? description;
const ogImageURL = new URL(ogImage, siteOrigin);

// Sitewide strukturierte Daten: WebSite + Person (Initiative/Autor).
// Bewusst kein Dentist-/MedicalBusiness-Schema – dies ist eine
// Standpunkt-Website, keine Praxiswerbung.
const baseGraph = [
  {
    "@type": "WebSite",
    "@id": `${siteOrigin}/#website`,
    url: `${siteOrigin}/`,
    name: "Standpunkt Dr. Roman Kubetschek",
    description:
      "Standpunkt zum Zahnärztemangel und zur Gesundheitspolitik in Mecklenburg-Vorpommern.",
    inLanguage: "de-DE",
    publisher: { "@id": `${siteOrigin}/#person` },
  },
  {
    "@type": "Person",
    "@id": `${siteOrigin}/#person`,
    name: "Dr. Roman Kubetschek",
    jobTitle: "Zahnarzt",
    url: `${siteOrigin}/`,
    address: {
      "@type": "PostalAddress",
      addressLocality: "Neubrandenburg",
      addressRegion: "Mecklenburg-Vorpommern",
      addressCountry: "DE",
    },
  },
];
const extra = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [...baseGraph, ...extra],
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Kritische Schriften vorab laden (selbst gehostet, kein CDN) -->
    <link rel="preload" href={interWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={playfairWoff2} as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Standpunkt Dr. Roman Kubetschek" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDesc} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDesc} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Keine externen Ressourcen, keine Tracker -->
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
