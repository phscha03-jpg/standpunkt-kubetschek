<script>
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ── Zahlen hochzählen (mit Dezimal-Unterstützung) ──────────────
  const fmt = (val: number, decimals: number) =>
    val.toFixed(decimals).replace(".", ",");

  const animateNum = (el: HTMLElement) => {
    const to = parseFloat(el.dataset.countTo!);
    const from = parseFloat(el.dataset.countFrom ?? "0");
    const decimals = parseInt(el.dataset.decimals ?? "0", 10);
    if (reduced) { el.textContent = fmt(to, decimals); return; }
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
    const duration = 1600;
    const start = performance.now();
    const tick = (now: number) => {
      const p = Math.min((now - start) / duration, 1);
      el.textContent = fmt(from + (to - from) * easeOut(p), decimals);
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  const numObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          animateNum(e.target as HTMLElement);
          numObserver.unobserve(e.target);
        }
      });
    },
    { threshold: 0.6 }
  );
  document.querySelectorAll<HTMLElement>("[data-count-to]").forEach((el) => numObserver.observe(el));

  // ── Diagramme einblenden (CSS-Übergänge per Klasse auslösen) ────
  const chartObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("is-visible");
          chartObserver.unobserve(e.target);
        }
      });
    },
    { threshold: 0.25 }
  );
  document.querySelectorAll<HTMLElement>("[data-chart]").forEach((el) => chartObserver.observe(el));
</script>
